<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AI Newsletter</title>
<style>
  :root { --bg: #fff; --fg: #1a1a1a; --muted: #666; --border: #e0e0e0; --accent: #2563eb; --card-bg: #f9fafb; }
  @media (prefers-color-scheme: dark) {
    :root { --bg: #0f172a; --fg: #e2e8f0; --muted: #94a3b8; --border: #334155; --accent: #60a5fa; --card-bg: #1e293b; }
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: var(--bg); color: var(--fg); max-width: 600px; margin: 0 auto; padding: 24px 16px; line-height: 1.6; }
  h1 { font-size: 1.5rem; margin-bottom: 24px; }
  h2 { font-size: 1.2rem; margin: 24px 0 12px; color: var(--muted); }
  ul { list-style: none; }
  li { margin-bottom: 8px; }
  a { color: var(--accent); text-decoration: none; font-size: 1.05rem; }
  a:hover { text-decoration: underline; }
  .empty { color: var(--muted); font-style: italic; }
</style>
</head>
<body>
<h1>AI Newsletter</h1>

<h2>Weekly Roundups</h2>
{% if weeklies %}
<ul>
{% for date in weeklies %}
  <li><a href="weekly/{{ date }}.html">Week of {{ date }}</a></li>
{% endfor %}
</ul>
{% else %}
<p class="empty">No weekly roundups yet.</p>
{% endif %}

<h2>Daily Briefings</h2>
{% if dailies %}
<ul>
{% for date in dailies %}
  <li><a href="daily/{{ date }}.html">{{ date }}</a></li>
{% endfor %}
</ul>
{% else %}
<p class="empty">No daily briefings yet.</p>
{% endif %}
</body>
</html>
